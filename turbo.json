{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "shared:build": {
      "dependsOn": [],
      "outputs": [
        "packages/bundlekit-shared-utils/dist/**"
      ]
    },
    "cli:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-cli/dist/**"
      ]
    },
    "service:build": {
      "dependsOn": [
        "shared:build",
        "webpack:build",
        "vite:build",
        "rollup:build",
        "rspack:build",
        "rolldown:build"
      ],
      "outputs": [
        "packages/bundlekit-service/dist/**"
      ]
    },
    "webpack:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-bundler-webpack/dist/**"
      ]
    },
    "vite:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-bundler-vite/dist/**"
      ]
    },
    "rollup:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-bundler-rollup/dist/**"
      ]
    },
    "rspack:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-bundler-rspack/dist/**"
      ]
    },
    "plugin:mock:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-plugin-mock/dist/**"
      ]
    },
    "request:build": {
      "dependsOn": [],
      "outputs": [
        "packages/bundlekit-request/dist/**"
      ]
    },
    "plugin:react:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-plugin-react/dist/**"
      ]
    },
    "plugin:vue:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-plugin-vue/dist/**"
      ]
    },
    "rolldown:build": {
      "dependsOn": [
        "shared:build"
      ],
      "outputs": [
        "packages/bundlekit-bundler-rolldown/dist/**"
      ]
    },
    "docs:build": {
      "dependsOn": [],
      "outputs": [
        "packages/bundlekit-docs/dist/**"
      ]
    }
  }
}