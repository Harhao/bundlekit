{
  "name": "@devkit/bundler-rollup",
  "version": "0.0.1",
  "description": "A rollup bundler for @devkit/service",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "rollup:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "dependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@devkit/shared-utils": "workspace:*",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.40.0",
    "rollup-plugin-postcss": "^4.0.2",
    "schema-utils": "^4.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.40.0",
    "tslib": "^2.6.2"
  },
  "keywords": [
    "rollup",
    "devkit-budnler-rollup",
    "devkit-bundler",
    "devkit"
  ],
  "author": "harhao@163.com",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
