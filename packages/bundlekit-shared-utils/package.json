{
  "name": "@bundlekit/shared-utils",
  "version": "0.0.11",
  "description": "bundlekit shared utils is common tools for bundlekit",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "debug": "tsx ./index.ts",
    "shared:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "files": [
    "dist",
    "package.json",
    "tsconfig.json"
  ],
  "keywords": [
    "bundlekit",
    "shared-utils",
    "bundlekit-shared-utils",
    "@bundlekit/shared-utils"
  ],
  "author": "harhao@163.com",
  "license": "MIT",
  "website": "https://bundlekit.harhao.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harhao/bundlekit.git",
    "directory": "packages/bundlekit-shared-utils"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.3.0",
    "ini": "^5.0.0",
    "lru-cache": "^11.1.0",
    "minimist": "^1.2.8",
    "open": "^10.1.1",
    "ora": "^6.3.1",
    "semver": "^7.7.1",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rspack/core": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "rollup": "^4.13.0",
    "tslib": "^2.6.2",
    "tsx": "^4.19.2",
    "vite": "^5.0.0",
    "webpack": "^5.0.0"
  },
  "peerDependencies": {
    "@rspack/core": "*",
    "rollup": "*",
    "vite": "*",
    "webpack": "*"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  }
}
