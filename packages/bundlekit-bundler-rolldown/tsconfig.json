{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "outDir": "./dist",
        "rootDir": ".",
        "preserveConstEnums": true,
        "removeComments": false,
        "sourceMap": false,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationDir": "./dist",
        "paths": {
            "@bundlekit/shared-utils": [
                "../bundlekit-shared-utils/lib/index.ts"
            ]
        },
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "scripts"
    ]
}