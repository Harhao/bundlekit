{
  "name": "@devkit/bundler-rolldown",
  "version": "0.0.1",
  "description": "Rolldown bundler adapter for @devkit/service",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "rolldown:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "dependencies": {
    "@devkit/shared-utils": "workspace:*",
    "less": "^4.2.2",
    "rolldown": "^1.0.1",
    "rollup-plugin-postcss": "^4.0.2"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rimraf": "^5.0.1",
    "rollup": "^4.40.0",
    "tslib": "^2.6.2"
  },
  "keywords": [
    "rolldown",
    "devkit-bundler",
    "devkit"
  ],
  "author": "harhao@163.com",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
