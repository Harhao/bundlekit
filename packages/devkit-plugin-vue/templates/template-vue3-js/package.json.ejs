{
  "name": "<%= projectName %>",
  "version": "1.0.0",
  "description": "<%= description %>",
  "scripts": {
    "clean": "rimraf dist",
    "dev": "devkit-service serve --bundler <%= bundler %> --mode development",
    "build": "devkit-service build --bundler <%= bundler %> --mode production"<% if (bundler === 'vite') { %>,
    "vite:dev": "npm run clean && devkit-service serve --bundler vite --mode development"<% } %><% if (bundler === 'webpack') { %>,
    "webpack:dev": "npm run clean && devkit-service serve --bundler webpack --mode development"<% } %>
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@devkit/service": "^0.0.1",
    "@vitejs/plugin-vue": "^5.2.0"
  }
}
