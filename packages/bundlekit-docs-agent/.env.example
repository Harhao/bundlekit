# Cloudflare Configuration
# 注意：敏感凭证已从 .env 文件中移除
# 请在 ~/.zshrc 中设置以下环境变量：
# export CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# export CLOUDFLARE_API_AI_TOKEN=your_cloudflare_api_token

# Vectorize Index Name
VECTORIZE_INDEX_NAME=bundlekit-docs

# Optional: Custom models
EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
CHAT_MODEL=@cf/meta/llama-3.1-8b-instruct

# Server Port
PORT=4111

# Environment Setup Instructions:
# 1. Set sensitive environment variables in ~/.zshrc:
#    export CLOUDFLARE_ACCOUNT_ID=your_account_id
#    export CLOUDFLARE_API_AI_TOKEN=your_api_token
# 2. Reload shell: source ~/.zshrc
# 3. Copy this file to .env if needed for non-sensitive configuration