{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Rspack Configuration Schema",
    "type": "object",
    "properties": {
        "entry": {
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "object",
                    "additionalProperties": {
                        "oneOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        ]
                    }
                }
            ]
        },
        "output": {
            "type": "object",
            "properties": {
                "path": {
                    "type": "string"
                },
                "filename": {
                    "type": "string"
                },
                "publicPath": {
                    "type": "string"
                },
                "chunkFilename": {
                    "type": "string"
                },
                "library": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "var",
                                        "module",
                                        "assign",
                                        "assign-properties",
                                        "this",
                                        "window",
                                        "self",
                                        "global",
                                        "commonjs",
                                        "commonjs2",
                                        "commonjs-module",
                                        "amd",
                                        "amd-require",
                                        "umd",
                                        "umd2",
                                        "jsonp",
                                        "system"
                                    ]
                                }
                            },
                            "required": [
                                "name",
                                "type"
                            ]
                        }
                    ]
                }
            },
            "required": [
                "path"
            ]
        },
        "module": {
            "type": "object",
            "properties": {
                "rules": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "test": {
                                "oneOf": [
                                    {
                                        "type": "string"
                                    },
                                    {
                                        "type": "object",
                                        "instanceof": "RegExp"
                                    }
                                ]
                            },
                            "use": {
                                "oneOf": [
                                    {
                                        "type": "string"
                                    },
                                    {
                                        "type": "array",
                                        "items": {
                                            "oneOf": [
                                                {
                                                    "type": "string"
                                                },
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "loader": {
                                                            "type": "string"
                                                        },
                                                        "options": {
                                                            "type": "object"
                                                        }
                                                    },
                                                    "required": [
                                                        "loader"
                                                    ]
                                                }
                                            ]
                                        }
                                    }
                                ]
                            }
                        },
                        "required": [
                            "test",
                            "use"
                        ]
                    }
                }
            }
        },
        "resolve": {
            "type": "object",
            "properties": {
                "extensions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "alias": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                }
            }
        },
        "plugins": {
            "type": "array",
            "items": {
                "type": "object"
            }
        },
        "mode": {
            "type": "string",
            "enum": [
                "development",
                "production",
                "none"
            ]
        },
        "devtool": {
            "type": "string"
        },
        "target": {
            "oneOf": [
                {
                    "type": "string",
                    "enum": [
                        "web",
                        "webworker",
                        "node",
                        "async-node",
                        "node-webkit",
                        "electron-main",
                        "electron-renderer",
                        "electron-preload"
                    ]
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "web",
                            "webworker",
                            "node",
                            "async-node",
                            "node-webkit",
                            "electron-main",
                            "electron-renderer",
                            "electron-preload"
                        ]
                    }
                }
            ]
        },
        "optimization": {
            "type": "object",
            "properties": {
                "minimize": {
                    "type": "boolean"
                },
                "splitChunks": {
                    "type": "object",
                    "properties": {
                        "chunks": {
                            "type": "string",
                            "enum": [
                                "all",
                                "async",
                                "initial"
                            ]
                        },
                        "minSize": {
                            "type": "number"
                        },
                        "maxSize": {
                            "type": "number"
                        },
                        "minChunks": {
                            "type": "number"
                        }
                    }
                }
            }
        },
        "devServer": {
            "type": "object",
            "properties": {
                "port": {
                    "type": "number"
                },
                "host": {
                    "type": "string"
                },
                "hot": {
                    "type": "boolean"
                },
                "open": {
                    "type": "boolean"
                },
                "proxy": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "target": {
                                "type": "string"
                            },
                            "changeOrigin": {
                                "type": "boolean"
                            },
                            "pathRewrite": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            }
                        },
                        "required": [
                            "target"
                        ]
                    }
                }
            }
        }
    },
    "additionalProperties": false
}