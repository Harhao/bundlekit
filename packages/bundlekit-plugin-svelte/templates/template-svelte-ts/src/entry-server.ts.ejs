import App from "./App.svelte";

/**
 * 服务端渲染入口
 *
 * @param url 当前请求路径，用于路由匹配
 * @returns HTML 字符串，将由 service 替换到 index.html 的 <!--ssr-outlet--> 占位
 *
 * Svelte 的 server-side render API：
 *   App.render(props) → { html, head, css: { code, map } }
 * 这里只返回 html；如需把 <head>、<style> 注入也可以扩展返回结构。
 */
export function render(url: string): string {
  // svelte 4 server bundle 导出的组件具备静态 render 方法
  const { html } = (App as any).render({ url });
  return html;
}
