{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "outDir": "./dist",
        "rootDir": "./",
        "preserveConstEnums": true,
        "removeComments": false,
        "sourceMap": true,
        "moduleResolution": "node",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "importHelpers": true,
        "paths": {
            "@bundlekit/shared-utils": ["../bundlekit-shared-utils/lib/index.ts"],
            "@bundlekit/bundler-vite": ["../bundlekit-bundler-vite/index.ts"],
            "@bundlekit/bundler-webpack": ["../bundlekit-bundler-webpack/index.ts"],
            "@bundlekit/bundler-rspack": ["../bundlekit-bundler-rspack/index.ts"],
            "@bundlekit/bundler-rollup": ["../bundlekit-bundler-rollup/index.ts"],
            "@bundlekit/bundler-rolldown": ["../bundlekit-bundler-rolldown/index.ts"]
        }
    },
    "include": [
        "lib/**/*.ts",
        "index.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "scripts"
    ]
}