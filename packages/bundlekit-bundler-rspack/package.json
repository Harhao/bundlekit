{
  "name": "@bundlekit/bundler-rspack",
  "version": "0.0.11",
  "description": "A rspack bundler for @bundlekit/service",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "rspack:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "files": [
    "dist",
    "tsconfig.json",
    "package.json"
  ],
  "keywords": [
    "rspack",
    "bundlekit-bundler",
    "bundlekit-budnler-rspack",
    "@bundlekit/bundler-rspack"
  ],
  "author": "harhao@163.com",
  "license": "MIT",
  "website": "https://bundlekit.harhao.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harhao/bundlekit.git",
    "directory": "packages/bundlekit-bundler-rspack"
  },
  "dependencies": {
    "@bundlekit/shared-utils": "workspace:*",
    "@rspack/core": "^1.3.4",
    "@rspack/dev-server": "^1.1.1",
    "schema-utils": "^4.3.0",
    "vue-loader": "^17.4.2",
    "webpack": "^5.99.7",
    "webpack-dev-middleware": "^7.4.2",
    "webpack-hot-middleware": "^2.26.1"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.40.0",
    "tslib": "^2.6.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
