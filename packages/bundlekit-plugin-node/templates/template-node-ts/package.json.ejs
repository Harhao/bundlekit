{
  "name": "<%= projectName %>",
  "version": "1.0.0",
  "description": "<%= description %>",
  "type": "module",
<% if (library && (bundler === 'rollup' || bundler === 'rolldown')) { %>
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
<% } else { %>
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
<% } %>
  "scripts": {
    "clean": "rimraf dist",
    "dev": "bundlekit-service serve --bundler <%= bundler %> --mode development",
    "build": "bundlekit-service build --bundler <%= bundler %> --mode production",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@bundlekit/service": "workspace:^",
    "@bundlekit/plugin-node": "workspace:^",
    "rimraf": "^5.0.1",
    "typescript": "^5.8.0"
  }
}
