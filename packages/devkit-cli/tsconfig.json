{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "outDir": "./dist",
        "rootDir": ".",
        "preserveConstEnums": true,
        "removeComments": false,
        "sourceMap": false,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "paths": {
            "@devkit/shared-utils": ["../devkit-shared-utils/lib/index.ts"]
        }
    },
    "include": [
        "index.tsx",
        "lib/**/*.ts",
        "lib/**/*.tsx",
        "types/**/*.ts"
     ],
    "exclude": [
        "node_modules",
        "package.json",
        "scripts",
        "dist",
        "tsconfig.json",
        "test-app",
        "**/test-app/**"
    ]
}