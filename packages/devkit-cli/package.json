{
  "name": "@devkit/cli",
  "version": "0.0.1",
  "description": "a cli tool serve for generate frontend project",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "devkit-cli": "./dist/index.cjs",
    "dc": "./dist/index.mjs"
  },
  "scripts": {
    "clean": "rimraf -rf dist",
    "debug": "tsx ./index.ts create test-app -t react-ts",
    "cli:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "devkit",
    "devkit-cli",
    "@devkit/cli"
  ],
  "author": "harhao@163.com",
  "license": "ISC",
  "dependencies": {
    "@devkit/plugin-react": "workspace:*",
    "@devkit/plugin-vue": "workspace:*",
    "@devkit/shared-utils": "workspace:*",
    "commander": "^13.1.0",
    "ejs": "^3.1.10",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/minimist": "^1.2.5",
    "@types/semver": "^7.7.0",
    "rimraf": "^5.0.1",
    "rollup": "^4.13.0",
    "rollup-plugin-header": "^1.0.0",
    "tslib": "^2.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
