{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://your-domain.com/vite.schema.json",
    "title": "Vite 4.3.9 Configuration Schema",
    "type": "object",
    "properties": {
        "root": {
            "type": "string",
            "description": "项目根目录"
        },
        "base": {
            "type": "string",
            "description": "部署基础路径"
        },
        "mode": {
            "type": "string",
            "description": "环境模式"
        },
        "define": {
            "type": "object",
            "description": "定义全局常量替换",
            "additionalProperties": true
        },
        "plugins": {
            "type": ["array", "null"],
            "description": "需要使用的插件数组",
            "items": {
                "anyOf": [
                    {
                        "type": "object"
                    },
                    {
                        "type": "array"
                    },
                    {
                        "type": "null"
                    }
                ]
            }
        },
        "publicDir": {
            "type": ["string", "boolean"],
            "description": "静态资源服务的文件夹，设置 false 可以禁用"
        },
        "cacheDir": {
            "type": "string",
            "description": "缓存文件存放的目录"
        },
        "resolve": {
            "type": "object",
            "description": "解析配置",
            "properties": {
                "alias": {
                    "type": "object",
                    "description": "路径别名设置"
                },
                "extensions": {
                    "type": "array",
                    "description": "导入时想要省略的扩展名列表",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "css": {
            "type": "object",
            "description": "CSS 相关配置",
            "properties": {
                "modules": {
                    "type": "object",
                    "description": "CSS modules 配置"
                },
                "preprocessorOptions": {
                    "type": "object",
                    "description": "CSS 预处理器配置"
                }
            }
        },
        "server": {
            "type": "object",
            "description": "开发服务器配置",
            "properties": {
                "host": {
                    "type": ["string", "boolean"],
                    "description": "指定服务器主机名"
                },
                "port": {
                    "type": "number",
                    "description": "指定服务器端口"
                },
                "https": {
                    "type": "boolean",
                    "description": "是否启用 TLS + HTTP/2"
                },
                "open": {
                    "type": ["boolean", "string"],
                    "description": "在服务器启动时自动在浏览器中打开应用程序"
                },
                "cors": {
                    "type": "boolean",
                    "description": "是否启用 CORS"
                },
                "hmr": {
                    "type": ["boolean", "object"],
                    "description": "热更新配置"
                },
                "watch": {
                    "type": "object",
                    "description": "文件监听配置"
                }
            }
        },
        "build": {
            "type": "object",
            "description": "构建配置",
            "properties": {
                "target": {
                    "type": ["string", "array"],
                    "description": "构建目标"
                },
                "outDir": {
                    "type": "string",
                    "description": "输出目录"
                },
                "assetsDir": {
                    "type": "string",
                    "description": "静态资源目录"
                },
                "sourcemap": {
                    "type": ["boolean", "string"],
                    "description": "是否生成 source map"
                },
                "minify": {
                    "type": ["boolean", "string"],
                    "description": "压缩配置"
                },
                "rollupOptions": {
                    "type": "object",
                    "description": "自定义底层的 Rollup 打包配置"
                }
            }
        },
        "optimizeDeps": {
            "type": "object",
            "description": "依赖优化选项",
            "properties": {
                "entries": {
                    "type": ["string", "array"],
                    "description": "自定义条目"
                },
                "exclude": {
                    "type": "array",
                    "description": "排除在优化之外的依赖",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    },
    "additionalProperties": true
}