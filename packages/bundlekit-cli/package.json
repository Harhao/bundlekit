{
  "name": "@bundlekit/cli",
  "version": "0.0.13",
  "description": "a cli tool serve for generate frontend project",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "bundlekit-cli": "./dist/index.mjs",
    "bc": "./dist/index.mjs"
  },
  "scripts": {
    "clean": "rimraf -rf dist",
    "debug": "tsx ./index.tsx create test-app -t react-ts --ssr",
    "cli:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "bundlekit",
    "bundlekit-cli",
    "@bundlekit/cli"
  ],
  "author": "harhao@163.com",
  "license": "MIT",
  "website": "https://bundlekit.harhao.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harhao/bundlekit.git",
    "directory": "packages/bundlekit-cli"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@bundlekit/plugin-react": "workspace:*",
    "@bundlekit/plugin-vue": "workspace:*",
    "@bundlekit/plugin-node": "workspace:*",
    "@bundlekit/shared-utils": "workspace:*",
    "commander": "^13.1.0",
    "ejs": "^3.1.10",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0",
    "ink": "^5.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/minimist": "^1.2.5",
    "@types/react": "^18.3.0",
    "@types/semver": "^7.7.0",
    "rimraf": "^5.0.1",
    "rollup": "^4.13.0",
    "rollup-plugin-header": "^1.0.0",
    "tslib": "^2.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
