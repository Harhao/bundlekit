{
  "name": "@bundlekit/bundler-vite",
  "version": "0.0.11",
  "description": "A vite bundler for @bundlekit/service",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "postinstall": "pnpm patch-package || exit 0",
    "vite:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "files": [
    "dist",
    "tsconfig.json",
    "package.json"
  ],
  "dependencies": {
    "@bundlekit/shared-utils": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^3.1.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "schema-utils": "^4.3.0",
    "svelte": "^4.2.0",
    "svelte-preprocess": "^5.1.0",
    "vite": "^4.3.9",
    "vite-plugin-html": "^3.2.2"
  },
  "keywords": [
    "vite",
    "bundlekit-bundler",
    "bundlekit-budnler-vite",
    "@bundlekit/bundler-vite"
  ],
  "author": "harhao@163.com",
  "license": "MIT",
  "website": "https://bundlekit.harhao.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harhao/bundlekit.git",
    "directory": "packages/bundlekit-bundler-vite"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.40.0",
    "tslib": "^2.6.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
