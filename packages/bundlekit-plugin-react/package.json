{
  "name": "@bundlekit/plugin-react",
  "version": "0.0.10",
  "description": "React plugin for bundlekit - provides React build support and project templates",
  "main": "./index.ts",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./generator": "./generator/index.ts"
  },
  "files": [
    "index.ts",
    "generator",
    "templates",
    "package.json"
  ],
  "scripts": {
    "plugin:react:build": "echo 'plugin:react built successfully'"
  },
  "keywords": [
    "react",
    "bundlekit-plugin",
    "bundlekit"
  ],
  "author": "harhao@163.com",
  "license": "MIT",
  "website": "https://bundlekit.harhao.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harhao/bundlekit.git",
    "directory": "packages/bundlekit-plugin-react"
  },
  "dependencies": {
    "@bundlekit/shared-utils": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
