export default {
  mode: "development",
  bundler: "<%= bundler %>",
  config: {
    development: {
      target: "web",
      publicPath: "/",
      entry: <% if (ssr) { %>"src/entry-client.jsx"<% } else { %>"src/index.jsx"<% } %>,
      // SSR 也保留 pages，让 client pass 走 bundler 原生 HTML 流水线，产物自带
      // <script>/<link> 注入，保留 split chunks 顺序、hash 等。
      pages: [
        { entry: <% if (ssr) { %>"src/entry-client.jsx"<% } else { %>"src/index.jsx"<% } %>, filename: "index.html", template: "public/index.html", inject: "body" },
      ],
      output: { dir: "dist", filename: "[name].js", formats: "umd" },
      alias: { "@": "src" },
      externals: [],
      js: { sourcemap: true, minify: false, splitChunks: true },
      devServer: { open: true, proxy: {}, https: false, host: "0.0.0.0", port: 3000 },<% if (ssr) { %>
      ssr: {
        entry: "src/entry-server.jsx",
        output: { dir: "dist/server", filename: "server.cjs", formats: "commonjs" },
        externals: "auto",
        // dev：HTML plugin 输出在内存，adapter 在 createSSRMiddleware 里手工注入 <script>，
        // 这里指向源模板即可。
        template: "public/index.html",
        placeholder: "<!--ssr-outlet-->",
        dev: true,
      },<% } %>
    },
  },
};
