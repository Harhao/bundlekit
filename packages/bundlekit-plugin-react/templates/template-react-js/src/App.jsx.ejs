import React, { useState } from "react";

function App() {
  const [count, setCount] = useState(0);

  return (
    <div>
      <h1>
        <span>Hello, <%= projectName %>!</span>
        <button onClick={() => setCount(count + 1)}>
          Clicked {count} times
        </button>
      </h1>
    </div>
  );
}

export default App;
