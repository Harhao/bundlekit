{
  "name": "@bundlekit/bundler-webpack",
  "version": "0.0.3",
  "description": "A webpack bundler for @bundlekit/service",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "cjs": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "tsconfig.json",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "webpack:build": "pnpm run clean && rollup -c ./scripts/rollup.config.js"
  },
  "dependencies": {
    "@bundlekit/shared-utils": "workspace:*",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "html-webpack-plugin": "^5.5.3",
    "less": "^4.1.3",
    "less-loader": "^11.1.3",
    "mini-css-extract-plugin": "^2.7.6",
    "schema-utils": "^4.3.0",
    "style-loader": "^3.3.3",
    "terser": "^5.18.0",
    "terser-webpack-plugin": "^5.3.14",
    "thread-loader": "^4.0.2",
    "ts-loader": "^9.4.4",
    "webpack": "^5.99.7",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-dev-middleware": "^7.4.2",
    "webpack-dev-server": "^5.2.0",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0",
    "workbox-webpack-plugin": "^7.3.0"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/webpack-hot-middleware": "^2.25.9",
    "@types/webpack-node-externals": "^3.0.4",
    "rollup": "^4.40.0",
    "tslib": "^2.6.2"
  },
  "keywords": [
    "webpack",
    "bundlekit-bundler",
    "bundlekit-budnler-webpack",
    "@bundlekit/bundler-webpack"
  ],
  "author": "harhao@163.com",
  "license": "MIT",
  "website": "https://bundlekit.harhao.workers.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harhao/bundlekit.git",
    "directory": "packages/bundlekit-bundler-webpack"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
