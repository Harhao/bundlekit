{
    "compilerOptions": {
        "target": "es2020",
        "module": "esnext",
        "lib": [ "esnext" ],
        "sourceMap": true,
        "esModuleInterop": true,
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
    },
    "ts-node": {
        "esm": true,
        "experimentalSpecifierResolution": "node"
    }
}